{
  "buildCommand": "npm install -g pnpm@11 && pnpm install --frozen-lockfile && pnpm --filter @workspace/site run build",
  "outputDirectory": "artifacts/site/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://agenthub-guru-claude-api.onrender.com/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/",
    "PORT": "3000"
  }
}
